import { Button } from "@/components/ui/button";
import { ArrowLeft, Check, Send, Upload, X, Zap } from "lucide-react";
import { useEffect, useRef, useState } from "react";

const QR_IMAGE =
  "/assets/uploads/whatsapp_image_2026-03-28_at_10.34.21_pm-019d358d-f4fa-771b-b3e7-0bfd522ee61a-1.jpeg";

const FREE_FIRE_LOGO =
  "/assets/generated/free-fire-logo-transparent.dim_400x200.png";

const TELEGRAM_ID = "Paanelseller";
const TELEGRAM_URL = `https://t.me/${TELEGRAM_ID}`;

const MAIN_ID_PLANS = [
  { duration: "7 Days", price: 300 },
  { duration: "30 Days", price: 500 },
  { duration: "60 Days", price: 649 },
  { duration: "Lifetime", price: 749 },
];

const NOOB_ID_PLANS = [
  { duration: "7 Days", price: 250 },
  { duration: "30 Days", price: 450 },
  { duration: "60 Days", price: 550 },
  { duration: "Lifetime", price: 700 },
];

function QRModal({
  plan,
  price,
  onClose,
}: { plan: string; price: number; onClose: () => void }) {
  const [step, setStep] = useState<1 | 2>(1);
  const [proofFile, setProofFile] = useState<File | null>(null);
  const [proofPreview, setProofPreview] = useState<string | null>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  function handleFileChange(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0] ?? null;
    setProofFile(file);
    if (file) {
      const url = URL.createObjectURL(file);
      setProofPreview(url);
    } else {
      setProofPreview(null);
    }
  }

  function handleClose() {
    if (proofPreview) URL.revokeObjectURL(proofPreview);
    onClose();
  }

  return (
    // biome-ignore lint/a11y/useKeyWithClickEvents: modal backdrop
    <div
      className="fixed inset-0 z-50 flex items-center justify-center p-4"
      style={{ background: "rgba(0,0,0,0.85)" }}
      onClick={handleClose}
    >
      {/* biome-ignore lint/a11y/useKeyWithClickEvents: stop propagation */}
      <div
        data-ocid="payment.modal"
        className="relative rounded-2xl p-6 max-w-sm w-full text-center transition-all duration-300"
        style={{
          background: "oklch(0.12 0.025 250 / 0.95)",
          border: "1px solid oklch(0.75 0.12 75 / 0.5)",
          backdropFilter: "blur(20px)",
          boxShadow: "0 0 60px oklch(0.75 0.12 75 / 0.3)",
          maxHeight: step === 2 ? "90vh" : undefined,
          overflowY: step === 2 ? "auto" : undefined,
        }}
        onClick={(e) => e.stopPropagation()}
      >
        <button
          type="button"
          onClick={handleClose}
          data-ocid="payment.close_button"
          className="absolute top-3 right-3 p-1 rounded-full transition-colors hover:bg-white/10"
          style={{ color: "oklch(0.72 0.02 240)" }}
        >
          <X className="w-5 h-5" />
        </button>

        {step === 1 ? (
          <>
            <p
              className="text-xs font-bold tracking-[0.3em] mb-1"
              style={{ color: "oklch(0.75 0.12 75)" }}
            >
              PAYMENT
            </p>
            <h3 className="font-serif text-xl font-bold text-white mb-1">
              {plan}
            </h3>
            <p className="text-3xl font-bold gold-text mb-4">
              {price} <span className="text-base">RS</span>
            </p>

            <div
              className="rounded-xl overflow-hidden mx-auto mb-4"
              style={{
                border: "2px solid oklch(0.75 0.12 75 / 0.5)",
                maxWidth: 260,
              }}
            >
              <img src={QR_IMAGE} alt="Payment QR Code" className="w-full" />
            </div>

            <p className="text-sm" style={{ color: "oklch(0.72 0.02 240)" }}>
              Scan the QR code to complete your payment
            </p>
            <p
              className="text-xs mt-2 mb-5"
              style={{ color: "oklch(0.72 0.02 240 / 0.6)" }}
            >
              After payment, click below to submit your proof
            </p>

            {/* I've Done Payment CTA */}
            <button
              type="button"
              data-ocid="payment.primary_button"
              onClick={() => setStep(2)}
              className="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-full font-bold text-sm tracking-wide transition-all duration-300 hover:scale-105 hover:shadow-lg mb-3"
              style={{
                background:
                  "linear-gradient(135deg, oklch(0.75 0.12 75) 0%, oklch(0.65 0.14 75) 100%)",
                color: "oklch(0.09 0.018 250)",
                boxShadow: "0 4px 20px oklch(0.75 0.12 75 / 0.4)",
              }}
            >
              <Check className="w-4 h-4" />
              I've Done Payment ✓
            </button>

            {/* Secondary Telegram button */}
            <a
              href={TELEGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
              data-ocid="payment.secondary_button"
              className="flex items-center justify-center gap-2 w-full py-2 px-4 rounded-full font-semibold text-xs tracking-wide transition-all duration-300 hover:scale-105"
              style={{
                background: "rgba(34,158,217,0.15)",
                color: "#229ED9",
                border: "1px solid rgba(34,158,217,0.4)",
              }}
            >
              <Send className="w-3 h-3" />
              Contact on Telegram
            </a>
            <p
              className="text-xs mt-2"
              style={{ color: "oklch(0.72 0.02 240 / 0.5)" }}
            >
              @{TELEGRAM_ID}
            </p>
          </>
        ) : (
          <>
            {/* Back button */}
            <button
              type="button"
              data-ocid="payment.cancel_button"
              onClick={() => setStep(1)}
              className="absolute top-3 left-3 flex items-center gap-1 p-1.5 rounded-full transition-colors hover:bg-white/10 text-xs"
              style={{ color: "oklch(0.72 0.02 240)" }}
            >
              <ArrowLeft className="w-4 h-4" />
            </button>

            {/* Success header */}
            <div className="mb-5 pt-2">
              <div className="text-3xl mb-2">🎉</div>
              <h3
                className="font-serif text-xl font-bold mb-1"
                style={{ color: "oklch(0.75 0.12 75)" }}
              >
                Payment Received!
              </h3>
              <p
                className="text-xs"
                style={{ color: "oklch(0.72 0.02 240 / 0.8)" }}
              >
                Please complete the steps below to get your panel
              </p>
            </div>

            {/* Upload Proof Section */}
            <div className="mb-4 text-left">
              <p
                className="text-xs font-bold tracking-widest mb-2 text-center"
                style={{ color: "oklch(0.75 0.12 75)" }}
              >
                UPLOAD PROOF OF PAYMENT
              </p>

              {/* biome-ignore lint/a11y/useKeyWithClickEvents: file upload area */}
              <div
                data-ocid="payment.dropzone"
                className="rounded-xl p-4 flex flex-col items-center justify-center gap-2 cursor-pointer transition-all duration-200 hover:border-opacity-80"
                style={{
                  border: "2px dashed oklch(0.75 0.12 75 / 0.5)",
                  background: "oklch(0.15 0.02 250 / 0.4)",
                  minHeight: proofPreview ? "auto" : 100,
                }}
                onClick={() => fileInputRef.current?.click()}
              >
                {proofPreview ? (
                  <img
                    src={proofPreview}
                    alt="Proof preview"
                    className="w-full rounded-lg max-h-36 object-cover"
                    style={{ border: "1px solid oklch(0.75 0.12 75 / 0.4)" }}
                  />
                ) : (
                  <>
                    <Upload
                      className="w-6 h-6"
                      style={{ color: "oklch(0.75 0.12 75)" }}
                    />
                    <p
                      className="text-xs font-semibold"
                      style={{ color: "oklch(0.75 0.12 75)" }}
                    >
                      Upload Payment Screenshot
                    </p>
                  </>
                )}
              </div>

              <input
                ref={fileInputRef}
                data-ocid="payment.upload_button"
                type="file"
                accept="image/*"
                className="hidden"
                onChange={handleFileChange}
              />

              {proofFile && (
                <p
                  className="text-xs mt-1 text-center"
                  style={{ color: "oklch(0.72 0.02 240 / 0.6)" }}
                >
                  {proofFile.name}
                </p>
              )}
              <p
                className="text-xs mt-2 text-center"
                style={{ color: "oklch(0.72 0.02 240 / 0.5)" }}
              >
                Upload your payment screenshot as proof
              </p>
            </div>

            {/* OR Separator */}
            <div className="flex items-center gap-3 my-4">
              <div
                className="flex-1 h-px"
                style={{ background: "oklch(0.75 0.12 75 / 0.25)" }}
              />
              <span
                className="text-xs font-bold tracking-widest"
                style={{ color: "oklch(0.72 0.02 240 / 0.6)" }}
              >
                OR
              </span>
              <div
                className="flex-1 h-px"
                style={{ background: "oklch(0.75 0.12 75 / 0.25)" }}
              />
            </div>

            {/* Direct DM on Telegram */}
            <p
              className="text-xs font-bold tracking-widest mb-3"
              style={{ color: "oklch(0.75 0.12 75)" }}
            >
              DIRECT DM ON TELEGRAM
            </p>
            <a
              href={TELEGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
              data-ocid="payment.primary_button"
              className="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-full font-bold text-sm tracking-wide transition-all duration-300 hover:scale-105 hover:shadow-lg"
              style={{
                background: "linear-gradient(135deg, #229ED9 0%, #1a7abf 100%)",
                color: "#fff",
                boxShadow: "0 4px 20px rgba(34,158,217,0.4)",
              }}
            >
              <Send className="w-4 h-4" />📩 Send Proof on Telegram
            </a>
            <p
              className="text-xs mt-2"
              style={{ color: "oklch(0.72 0.02 240 / 0.5)" }}
            >
              @{TELEGRAM_ID}
            </p>
          </>
        )}
      </div>
    </div>
  );
}

function PricingCard({
  duration,
  price,
  index,
  featured,
  panelName,
  onBuy,
}: {
  duration: string;
  price: number;
  index: number;
  featured?: boolean;
  panelName: string;
  onBuy: (plan: string, price: number) => void;
}) {
  return (
    <div
      className="fade-in-up relative flex flex-col rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 gold-glow-hover"
      style={{
        transitionDelay: `${index * 0.08}s`,
        background: featured
          ? "oklch(0.16 0.03 75 / 0.4)"
          : "rgba(18, 24, 38, 0.65)",
        border: featured
          ? "1px solid oklch(0.75 0.12 75 / 0.7)"
          : "1px solid oklch(0.75 0.12 75 / 0.2)",
        backdropFilter: "blur(12px)",
        boxShadow: featured ? "0 0 30px oklch(0.75 0.12 75 / 0.3)" : undefined,
      }}
    >
      {featured && (
        <div className="absolute -top-3 left-1/2 -translate-x-1/2">
          <span
            className="px-3 py-1 text-xs font-bold tracking-[0.2em] rounded-full"
            style={{
              background: "oklch(0.75 0.12 75)",
              color: "oklch(0.09 0.018 250)",
            }}
          >
            BEST VALUE
          </span>
        </div>
      )}

      <div className="text-center mb-4 mt-2">
        <p
          className="text-sm font-bold tracking-widest uppercase mb-3"
          style={{ color: "oklch(0.72 0.02 240)" }}
        >
          {duration}
        </p>
        <p className="text-4xl font-bold gold-text">{price}</p>
        <p className="text-sm mt-1" style={{ color: "oklch(0.72 0.02 240)" }}>
          RS
        </p>
      </div>

      <ul className="flex flex-col gap-2 mb-6 flex-1">
        {["Instant Delivery", "24/7 Support", "Full Access"].map((f) => (
          <li
            key={f}
            className="flex items-center gap-2 text-sm text-foreground"
          >
            <Check
              className="w-4 h-4 flex-shrink-0"
              style={{ color: "oklch(0.75 0.12 75)" }}
            />
            {f}
          </li>
        ))}
      </ul>

      <Button
        className="w-full gold-gradient text-[oklch(0.09_0.018_250)] font-bold tracking-wide rounded-full hover:shadow-gold-lg transition-all duration-300"
        onClick={() => onBuy(`${panelName} - ${duration}`, price)}
      >
        BUY NOW
      </Button>
    </div>
  );
}

function PanelSection({
  title,
  plans,
  startIndex,
  onBuy,
  showLogo,
}: {
  title: string;
  plans: { duration: string; price: number }[];
  startIndex: number;
  onBuy: (plan: string, price: number) => void;
  showLogo?: boolean;
}) {
  return (
    <div className="mb-16">
      <div className="text-center mb-8">
        {showLogo && (
          <div className="fade-in-up flex justify-center mb-3">
            <img
              src={FREE_FIRE_LOGO}
              alt="Free Fire"
              className="h-20 md:h-24 object-contain drop-shadow-[0_0_20px_rgba(255,120,0,0.7)]"
              style={{ filter: "drop-shadow(0 0 16px rgba(255,100,0,0.8))" }}
            />
          </div>
        )}
        <p
          className="fade-in-up text-xs font-bold tracking-[0.3em] mb-2"
          style={{ color: "oklch(0.75 0.12 75)" }}
        >
          PRICING
        </p>
        <h3
          className="fade-in-up font-serif text-3xl md:text-4xl text-foreground"
          style={{ transitionDelay: "0.05s" }}
        >
          <span className="gold-text">{title}</span>
        </h3>
      </div>
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {plans.map((plan, i) => (
          <PricingCard
            key={plan.duration}
            duration={plan.duration}
            price={plan.price}
            index={startIndex + i}
            featured={plan.duration === "Lifetime"}
            panelName={title}
            onBuy={onBuy}
          />
        ))}
      </div>
    </div>
  );
}

export default function Products() {
  const ref = useRef<HTMLElement>(null);
  const [modal, setModal] = useState<{ plan: string; price: number } | null>(
    null,
  );

  useEffect(() => {
    const el = ref.current;
    if (!el) return;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) e.target.classList.add("visible");
        }
      },
      { threshold: 0.05 },
    );
    const check = () => {
      for (const c of el.querySelectorAll(".fade-in-up")) observer.observe(c);
    };
    check();
    const mo = new MutationObserver(check);
    mo.observe(el, { childList: true, subtree: true });
    return () => {
      observer.disconnect();
      mo.disconnect();
    };
  }, []);

  return (
    <>
      {modal && (
        <QRModal
          plan={modal.plan}
          price={modal.price}
          onClose={() => setModal(null)}
        />
      )}
      <section
        id="panels"
        ref={ref as React.RefObject<HTMLElement>}
        className="py-20 section-divider"
      >
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="text-center mb-14">
            <p
              className="fade-in-up text-xs font-bold tracking-[0.3em] mb-3"
              style={{ color: "oklch(0.75 0.12 75)" }}
            >
              CHOOSE YOUR PLAN
            </p>
            <h2
              className="fade-in-up font-serif text-4xl md:text-5xl text-foreground"
              style={{ transitionDelay: "0.1s" }}
            >
              Our <span className="gold-text">Panels</span>
            </h2>

            {/* Google Verified Badge */}
            <div
              className="fade-in-up inline-flex items-center gap-2 mt-4 px-4 py-1.5 rounded-full"
              style={{
                transitionDelay: "0.15s",
                background: "rgba(15, 20, 35, 0.7)",
                border: "1px solid rgba(255,255,255,0.12)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 2px 12px rgba(0,0,0,0.3)",
              }}
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                role="img"
                aria-label="Google"
              >
                <title>Google</title>
                <path
                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                  fill="#4285F4"
                />
                <path
                  d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                  fill="#34A853"
                />
                <path
                  d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                  fill="#FBBC05"
                />
                <path
                  d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                  fill="#EA4335"
                />
              </svg>
              <span
                className="text-xs font-semibold tracking-wide"
                style={{ color: "rgba(255,255,255,0.85)" }}
              >
                Verified by Google
              </span>
            </div>
          </div>

          <PanelSection
            title="MAIN ID PANNEL"
            plans={MAIN_ID_PLANS}
            startIndex={0}
            showLogo
            onBuy={(plan, price) => setModal({ plan, price })}
          />

          <div
            className="fade-in-up border-t my-4 mb-16"
            style={{ borderColor: "oklch(0.75 0.12 75 / 0.2)" }}
          />

          <PanelSection
            title="NOOB ID PANNEL"
            plans={NOOB_ID_PLANS}
            startIndex={4}
            onBuy={(plan, price) => setModal({ plan, price })}
          />

          <div
            className="fade-in-up mt-4 flex items-center justify-center gap-2 text-sm"
            style={{ color: "oklch(0.72 0.02 240)" }}
          >
            <Zap className="w-4 h-4" style={{ color: "oklch(0.75 0.12 75)" }} />
            All packages include instant delivery and dedicated onboarding
            support
          </div>
        </div>
      </section>
    </>
  );
}
